# 이 파일을 복사해 .env 로 저장한 뒤 값을 채우세요.
#   copy .env.example .env        (Windows)
#   cp .env.example .env          (Linux/macOS)

# ── DB alias (SQL 파일 상단 -- @db: <alias> 와 매칭) ─────────────────────────
# 미지정 쿼리는 DB_DEFAULT_ALIAS 사용
DB_DEFAULT_ALIAS=main

# alias "main" (MES/운영 DB 예시)
DB_MAIN_USER=your_oracle_user
DB_MAIN_PASSWORD=your_oracle_password
DB_MAIN_DSN=hostname:1521/ORCL

# alias 추가 예: plan 전용 DB
# DB_PLAN_USER=plan_user
# DB_PLAN_PASSWORD=plan_password
# DB_PLAN_DSN=plan-host:1521/ORCL
# → external/sql/plan.sql 첫 줄: -- @db: plan

# 하위 호환 (DB_MAIN_* 미설정 시 main alias 로 사용)
ORACLE_USER=your_oracle_user
ORACLE_PASSWORD=your_oracle_password
ORACLE_DSN=hostname:1521/ORCL

# ── Collector (python -m data.collector / python main.py collect) ─────────────
COLLECTOR_FAC_ID=FAC001
COLLECTOR_SPLIT=train
COLLECTOR_INTERVAL_SEC=3600
COLLECTOR_PREVDAYS=1

# (선택) 기본 dataset 입력 경로 - 미설정 시 CLI 인자 기준
# SCHEDULING_INPUT=FAC001/train/20260621170000
