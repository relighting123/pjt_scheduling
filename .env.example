# 이 파일을 복사해 .env 로 저장한 뒤 값을 채우세요.
#   cp .env.example .env

# ── DB (계층 YAML – 권장) ─────────────────────────────────────────────────────
# config/databases.yaml.example → config/databases.yaml 복사 후 Prd/Dev 등 설정
DB_CONFIG=config/databases.yaml
DB_DEFAULT_ALIAS=Prd

# SQL 예: -- @db: Prd  /  -- @db: Dev  /  -- @db: Prd.Plan

# ── DB (평면 .env – 하위 호환, YAML 없을 때) ─────────────────────────────────
# ORACLE_USER=your_oracle_user
# ORACLE_PASSWORD=your_oracle_password
# ORACLE_DSN=hostname:1521/ORCL

# ── Collector ────────────────────────────────────────────────────────────────
COLLECTOR_FAC_ID=FAC001
COLLECTOR_SPLIT=train
COLLECTOR_INTERVAL_SEC=3600
COLLECTOR_PREVDAYS=1

# SCHEDULING_INPUT=FAC001/train/20260621170000
