# 이 파일을 복사해 .env 로 저장한 뒤 값을 채우세요.
#   cp .env.example .env

# ── DB (계층 YAML – 권장) ─────────────────────────────────────────────────────
# config/databases.yaml.example → config/databases.yaml 복사 후 alias 블록 설정
DB_CONFIG=config/databases.yaml
# databases.yaml 의 default 와 맞출 것 (예: Prd, WT_RTS). 없으면 yaml default 사용.
# DB_DEFAULT_ALIAS=WT_RTS

# ── 운영/개발 서버 분리 (선택) ────────────────────────────────────────────────
# DB_CONFIG 를 비워두면 APP_ENV 로 설정 파일을 자동 선택합니다.
#   APP_ENV=production → config/databases.prd.yaml
#   APP_ENV=development → config/databases.dev.yaml
# config/databases.prd.yaml.example / databases.dev.yaml.example 를 각각 복사해 채우세요.
# DB_CONFIG 를 명시하면 이 값보다 우선 적용됩니다.
# APP_ENV=production

# SQL 예: -- @db: WT_RTS  /  @db:WT_RTS  /  -- @db: Prd.Plan
# RULE_TIMEKEY 메타 SQL (data/sql.example/rule_timekey_*.sql 참고)
# RULE_TIMEKEY_FROM_DB=1   # 1=강제, 0=비활성, 미설정=sql 파일 있으면 자동

# ── DB (평면 .env – 하위 호환, YAML 없을 때) ─────────────────────────────────
# ORACLE_USER=your_oracle_user
# ORACLE_PASSWORD=your_oracle_password
# ORACLE_DSN=hostname:1521/ORCL

# ── Collector ────────────────────────────────────────────────────────────────
COLLECTOR_FAC_ID=FAC001
COLLECTOR_SPLIT=train
COLLECTOR_INTERVAL_SEC=3600
COLLECTOR_PREVDAYS=1
# COLLECTOR_LOT_CD=LC001
# SQL_LOT_CD=LC001

# SCHEDULING_INPUT=FAC001/train/20260621170000
