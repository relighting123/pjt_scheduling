# Python
__pycache__/
*.pyc
*.pyo
.venv/
venv/
*.egg-info/
dist/
build/

# External dataset (JSON 산출물, git 제외) – SQL 템플릿은 추적
data/dataset/

# Oracle 실행용 SQL (환경별 커스텀) – 템플릿은 data/sql.example/ 추적
data/sql/*
!data/sql/.gitkeep

# Trained models (large binary files – checkpoints/best 등 하위 경로 포함)
models/**
!models/.gitkeep

# IDE
.vscode/
.idea/

# Logs & temp
*.log
logs/
logging/
.env
config/databases.yaml
config/databases.prd.yaml
config/databases.dev.yaml
frontend/node_modules/
frontend/dist/

# 실험 산출물 (재현 가능, chat로 보고)
experiment_results.json
